# Copy this file to .env and fill in values before running docker compose.
# .env is gitignored — never commit real credentials.

# PostgreSQL credentials (used by the postgres container)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Full connection URL (used by the FastAPI backend)
# Format: postgresql://<user>:<password>@postgres:5432/<db>
DATABASE_URL=

# PostHog analytics — leave blank to disable (no tracking in dev/CI)
NEXT_PUBLIC_POSTHOG_KEY=
# Optional: override PostHog ingest host (default: https://us.i.posthog.com)
# NEXT_PUBLIC_POSTHOG_HOST=

# Redis cache URL — leave blank to disable caching (app works without it)
# Docker Compose default: redis://redis:6379/0
REDIS_URL=

# Graph version — bump this (e.g. "1" → "2") after ingesting new data, then
# restart the backend. Every worker detects the mismatch on its next request
# and rebuilds its in-memory graph. Defaults to "1" if unset.
GRAPH_VERSION=1

# Sentry — backend DSN (leave blank to disable)
SENTRY_DSN=

# Sentry — frontend DSN (leave blank to disable; baked into JS bundle at build time)
NEXT_PUBLIC_SENTRY_DSN=
# Optional: upload source maps for readable stack traces in Sentry
# SENTRY_AUTH_TOKEN=

# Secret key for POST /admin/rebuild-graph — leave blank to disable the endpoint
ADMIN_API_KEY=
