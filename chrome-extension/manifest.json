{
  "manifest_version": 3,
  "name": "South Cinema Insights",
  "version": "1.0.0",
  "description": "Highlight any actor name to instantly see their South Indian cinema analytics.",

  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://api.southcinema.app/*"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config.js", "content.js"],
      "css": ["popup.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "South Cinema Insights"
  }
}
